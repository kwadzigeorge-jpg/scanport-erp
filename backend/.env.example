DATABASE_URL="postgresql://postgres:password@localhost:5432/scanport?schema=public"

JWT_SECRET="change-this-to-a-secure-random-string-in-production"
JWT_EXPIRES_IN="7d"

PORT=4000
FRONTEND_URL="http://localhost:5173"

# ── Email (SMTP) ──────────────────────────────────────────────────────────────
# Gmail: enable 2FA, then create an App Password at myaccount.google.com/apppasswords
SMTP_HOST="smtp.gmail.com"
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER="your-email@gmail.com"
SMTP_PASS="your-16-char-app-password"
EMAIL_FROM="ScanPort System <noreply@scanport.com>"
# Comma-separated recipients for automated alert emails
ALERT_EMAIL="portops@yourport.com,manager@yourport.com"

# ── WhatsApp (Twilio) ─────────────────────────────────────────────────────────
# Sign up at twilio.com → activate WhatsApp sandbox → get credentials
TWILIO_ACCOUNT_SID=""
TWILIO_AUTH_TOKEN=""
TWILIO_WHATSAPP_FROM="whatsapp:+14155238886"
# Comma-separated WhatsApp numbers (international format, no spaces)
WHATSAPP_ALERT_TO="+233201234567,+233209876543"

# ── Port Authority identity (used in NRA letters) ─────────────────────────────
PORT_AUTHORITY_NAME="Ghana Ports and Harbours Authority"
PORT_AUTHORITY_ADDRESS="P.O. Box 150, Tema, Ghana"
PORT_AUTHORITY_TEL="+233 303 000 000"
PORT_AUTHORITY_EMAIL="portops@ghanaports.gov.gh"
NRA_ADDRESS="Nuclear Regulatory Authority\nP.O. Box CT 1674\nAccra, Ghana"

# ── Backup ────────────────────────────────────────────────────────────────────
BACKUP_RETAIN_DAYS=30
