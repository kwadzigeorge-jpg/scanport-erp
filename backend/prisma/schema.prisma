generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id               String           @id @default(cuid())
  email            String           @unique
  password         String
  name             String
  role             String           @default("VIEWER")
  createdAt        DateTime         @default(now())
  updatedAt        DateTime         @updatedAt
  reportedTickets  Ticket[]         @relation("ReportedByTickets")
  assignedTickets  Ticket[]         @relation("AssignedToTickets")
  ticketActivities TicketActivity[]
  agentRequests    AgentRequest[]   @relation("SubmittedAgentRequests")
  created_gangs    Gang[]           @relation("GangCreatedBy")
  received_gang_requests GangRequest[] @relation("GangRequestReceivedBy")
  gang_allocations GangAllocation[] @relation("GangAllocatedBy")
  gang_delay_reports    GangDelayLog[]     @relation("GangDelayReportedBy")
  gang_substitutions    GangSubstitution[] @relation("SubstitutionCreatedBy")
}

model Scanner {
  id                String          @id @default(cuid())
  serialNumber      String          @unique
  acceleratorSerial String
  manufacturer      String          @default("Siemens")
  type              String          @default("Fixed Scanner")
  location          String?
  createdAt         DateTime        @default(now())
  updatedAt         DateTime        @updatedAt
  certifications    Certification[]
}

model Certification {
  id                String         @id @default(cuid())
  scannerId         String
  scanner           Scanner        @relation(fields: [scannerId], references: [id], onDelete: Cascade)
  inspectionDate    DateTime
  expiryDate        DateTime
  noticeDate        DateTime
  certificateStatus String         @default("ISSUED")
  status            String         @default("ACTIVE")
  documentUrl       String?
  documentName      String?
  createdAt         DateTime       @default(now())
  updatedAt         DateTime       @updatedAt
  notifications     Notification[]
  alertLogs         AlertLog[]
}

model Notification {
  id              String        @id @default(cuid())
  certificationId String
  certification   Certification @relation(fields: [certificationId], references: [id], onDelete: Cascade)
  noticeStatus    String        @default("NOT_SENT")
  dateSent        DateTime?
  method          String?
  referenceNumber String?
  documentUrl     String?
  notes           String?
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
}

model AuditLog {
  id        String   @id @default(cuid())
  userId    String
  userEmail String
  action    String
  entity    String
  entityId  String
  details   String   @default("")
  createdAt DateTime @default(now())
}

model AlertLog {
  id              String        @id @default(cuid())
  certificationId String
  certification   Certification @relation(fields: [certificationId], references: [id], onDelete: Cascade)
  type            String
  message         String
  resolved        Boolean       @default(false)
  createdAt       DateTime      @default(now())
}

// ─── Incident Management ─────────────────────────────────────────────────────

model Location {
  id      String   @id @default(cuid())
  name    String   @unique
  code    String   @unique
  type    String
  tickets Ticket[]
}

model Ticket {
  id              String           @id @default(cuid())
  ticketNumber    String           @unique
  title           String
  description     String
  locationId      String
  location        Location         @relation(fields: [locationId], references: [id])
  equipmentType   String
  issueType       String
  severity        String
  status          String           @default("OPEN")
  escalationLevel Int              @default(1)
  reportedById    String
  reportedBy      User             @relation("ReportedByTickets", fields: [reportedById], references: [id])
  assignedTo      String?
  assignedToId    String?
  assignedToUser  User?            @relation("AssignedToTickets", fields: [assignedToId], references: [id])
  startTime       DateTime         @default(now())
  firstResponseAt DateTime?
  resolvedAt      DateTime?
  closedAt        DateTime?
  resolutionNotes String?
  downtimeMinutes Int?
  slaBreached     Boolean          @default(false)
  attachments     Attachment[]
  activities      TicketActivity[]
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
}

model TicketActivity {
  id         String   @id @default(cuid())
  ticketId   String
  ticket     Ticket   @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  userId     String
  user       User     @relation(fields: [userId], references: [id])
  userEmail  String
  userName   String
  action     String
  fromStatus String?
  toStatus   String?
  notes      String?
  createdAt  DateTime @default(now())
}

model Attachment {
  id        String   @id @default(cuid())
  ticketId  String
  ticket    Ticket   @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  fileName  String
  fileUrl   String
  fileType  String
  createdAt DateTime @default(now())
}

// ─── Scanner Status Board ─────────────────────────────────────────────────────

model ScannerBoardEntry {
  id           String   @id @default(cuid())
  date         String   // YYYY-MM-DD
  shift        String   // MORNING | AFTERNOON | NIGHT
  scanner      String   // IMPORT_1 | IMPORT_2 | IMPORT_3 | EXPORT_1 | EXPORT_2 | EXPORT_3
  status       String   @default("OPERATIONAL")
  faultType    String?
  faultNote    String?
  updateRemark String?
  scanCount    Int      @default(0)
  preparedBy   String?
  sessionId    Int      @default(0)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@unique([date, shift, scanner])
}

model BoardHistory {
  id        String   @id @default(cuid())
  date      String
  shift     String
  scanner   String
  changes   String   // JSON array of {field, from, to}
  updatedBy String
  sessionId Int      @default(0)
  createdAt DateTime @default(now())
}

// ─── Agent Requests ───────────────────────────────────────────────────────────

model AgentRequest {
  id              String    @id @default(cuid())
  requestNumber   String    @unique                // AGT-2026-0001
  requestType     String                           // SEAL_CUTTING | GANG_UNSTUFFING
  status          String    @default("PENDING")    // PENDING | APPROVED | IN_PROGRESS | COMPLETED | REJECTED

  // Container info — required for both request types
  containerNumber String
  containerSize   String                           // 20FT | 40FT | 45FT
  sealNumber      String?

  // Gang-for-unstuffing additional fields
  bayZone         String?                          // "1-50" | "51-80"
  bayNumber       String?
  gangAssigned    String?
  agencyName      String?
  agentName       String?
  agentPhone      String?
  itemDescription String?
  completionTime  DateTime?

  notes           String?
  submittedById   String
  submittedBy     User      @relation("SubmittedAgentRequests", fields: [submittedById], references: [id])
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
}

// ─── Gang Management ──────────────────────────────────────────────────────────

model Gang {
  id                   String    @id @default(cuid())
  gang_code            String    @unique
  status               String    @default("available")
  specialization       String?
  performance_score    Float     @default(100.0)
  total_jobs_completed Int       @default(0)
  notes                String?
  created_by           String?
  created_at           DateTime  @default(now())
  updated_at           DateTime  @updatedAt

  creator                 User?                   @relation("GangCreatedBy", fields: [created_by], references: [id])
  members                 GangMember[]
  allocations             GangAllocation[]        @relation("GangJobAllocations")
  recommended_allocations GangAllocation[]        @relation("GangEngineRecommended")
  notifications           GangNotification[]
  performance_records     GangPerformanceRecord[]
  substitutions           GangSubstitution[]      @relation("GangSubstitutions")
}

model GangMember {
  id          String    @id @default(cuid())
  gang_id     String
  role        String
  full_name   String
  employee_id String    @unique
  phone       String?
  is_active   Boolean   @default(true)
  joined_date DateTime?
  status      String    @default("available")
  created_at  DateTime  @default(now())

  gang                Gang               @relation(fields: [gang_id], references: [id], onDelete: Cascade)
  absences            GangSubstitution[] @relation("AbsentMember")
  substituting_for    GangSubstitution[] @relation("SubstituteMember")
}

model GangRequest {
  id                 String    @id @default(cuid())
  request_ref        String    @unique
  agent_name         String
  agent_phone        String?
  agency             String?
  bay_number         String
  container_number   String
  container_number_2 String?
  is_dual_container  Boolean   @default(false)
  cargo_type         String?
  priority           String    @default("normal")
  status             String    @default("pending")
  notes              String?
  received_by        String?
  created_at         DateTime  @default(now())
  updated_at         DateTime  @updatedAt

  receiver    User?            @relation("GangRequestReceivedBy", fields: [received_by], references: [id])
  allocations GangAllocation[]
}

model GangAllocation {
  id                        String    @id @default(cuid())
  request_id                String
  gang_id                   String
  allocated_by              String
  is_override               Boolean   @default(false)
  override_reason           String?
  engine_recommended_gang   String?
  engine_score              Float?
  expected_start            DateTime?
  expected_duration_minutes Int       @default(60)
  allocated_at              DateTime  @default(now())
  gang_arrived_at           DateTime?
  work_started_at           DateTime?
  work_completed_at         DateTime?
  status                    String    @default("allocated")
  supervisor_comments       String?
  agent_rating              Int?
  agent_feedback            String?
  created_at                DateTime  @default(now())
  updated_at                DateTime  @updatedAt

  request          GangRequest            @relation(fields: [request_id], references: [id])
  gang             Gang                   @relation("GangJobAllocations", fields: [gang_id], references: [id])
  allocator        User                   @relation("GangAllocatedBy", fields: [allocated_by], references: [id])
  recommended_gang Gang?                  @relation("GangEngineRecommended", fields: [engine_recommended_gang], references: [id])
  delay_logs       GangDelayLog[]
  performance_record GangPerformanceRecord?
  notifications    GangNotification[]
}

model GangDelayLog {
  id            String    @id @default(cuid())
  allocation_id String
  delay_type    String
  delay_minutes Int?
  description   String
  reported_by   String?
  reported_at   DateTime  @default(now())

  allocation    GangAllocation @relation(fields: [allocation_id], references: [id], onDelete: Cascade)
  reporter      User?          @relation("GangDelayReportedBy", fields: [reported_by], references: [id])
}

model GangPerformanceRecord {
  id                        String    @id @default(cuid())
  gang_id                   String
  allocation_id             String?   @unique
  period_date               DateTime
  actual_duration_minutes   Int?
  expected_duration_minutes Int?
  delay_count               Int       @default(0)
  agent_rating              Int?
  arrived_on_time           Boolean?
  duration_score            Float?
  delay_score               Float?
  arrival_score             Float?
  rating_score              Float?
  total_score               Float?
  computed_at               DateTime  @default(now())

  gang       Gang            @relation(fields: [gang_id], references: [id], onDelete: Cascade)
  allocation GangAllocation? @relation(fields: [allocation_id], references: [id], onDelete: Cascade)
}

model GangNotification {
  id            String    @id @default(cuid())
  type          String
  message       String
  allocation_id String?
  gang_id       String?
  is_read       Boolean   @default(false)
  created_at    DateTime  @default(now())

  allocation GangAllocation? @relation(fields: [allocation_id], references: [id], onDelete: Cascade)
  gang       Gang?           @relation(fields: [gang_id], references: [id], onDelete: Cascade)
}

model ShiftDeploymentLimit {
  id          String @id @default(cuid())
  day_of_week Int    // 0=Sunday … 6=Saturday
  shift       String // 'day' | 'night'
  max_gangs   Int

  @@unique([day_of_week, shift])
}

model GangSubstitution {
  id               String    @id @default(cuid())
  gang_id          String
  absent_member_id String
  substitute_id    String
  reason           String?
  notes            String?
  created_by       String
  ended_at         DateTime?
  created_at       DateTime  @default(now())

  gang          Gang       @relation("GangSubstitutions", fields: [gang_id], references: [id])
  absent_member GangMember @relation("AbsentMember", fields: [absent_member_id], references: [id])
  substitute    GangMember @relation("SubstituteMember", fields: [substitute_id], references: [id])
  creator       User       @relation("SubstitutionCreatedBy", fields: [created_by], references: [id])
}
