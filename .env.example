# Copy to .env and fill in real values

# ── Database ─────────────────────────────────────────────────────────────────
# Railway provides DATABASE_URL automatically — set that OR the individual vars below
DATABASE_URL=postgresql://user:password@host:5432/dbname

# Individual vars (used when DATABASE_URL is absent / local dev)
DB_NAME=port_terminal_erp
DB_USER=postgres
DB_PASSWORD=CHANGE_ME_STRONG_PASSWORD
DB_HOST=localhost
DB_PORT=5432

# ── Secrets ───────────────────────────────────────────────────────────────────
# Generate: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=CHANGE_ME_64CHAR_RANDOM_STRING

# ── URLs (set to your production domain with https) ───────────────────────────
CORS_ORIGIN=https://yourdomain.com
QR_CODE_BASE_URL=https://yourdomain.com

# ── Admin seed account (used once on first deploy) ────────────────────────────
ADMIN_USERNAME=admin
ADMIN_PASSWORD=ChangeMe@123!
ADMIN_EMAIL=admin@yourdomain.com
